---
import type { Product } from "../data/products";

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<div class="group relative flex flex-col rounded-xl border border-line/70 bg-surface/50 p-6 transition-all hover:border-accent/50 hover:shadow-lg">
  <div class="mb-4 aspect-square rounded-lg bg-bg/80 flex items-center justify-center border border-line/30 group-hover:border-accent/20">
    <span class="text-xs uppercase tracking-widest text-muted group-hover:text-accent/70 transition-colors">Tactical Scent {product.id.split('-')[0]}</span>
  </div>

  <div class="flex justify-between items-start mb-2">
    <h3 class="font-heading text-xl uppercase leading-none">{product.name}</h3>
    <span class="font-heading text-accent">${product.price}</span>
  </div>

  <p class="text-xs font-medium uppercase tracking-wider text-muted mb-4">{product.category}</p>

  <div class="space-y-4 flex-1">
    <div>
      <p class="text-[10px] uppercase tracking-[0.2em] text-accent/80 mb-1">Scent Profile</p>
      <p class="text-sm leading-relaxed">{product.scentProfile}</p>
    </div>

    <div>
      <p class="text-[10px] uppercase tracking-[0.2em] text-accent/80 mb-1">Tactical Note</p>
      <p class="text-sm italic text-muted leading-relaxed">{product.tacticalNote}</p>
    </div>
  </div>

  <button class="mt-6 w-full rounded-lg border border-line py-2.5 text-xs uppercase tracking-widest transition-all hover:bg-accent hover:text-bg hover:border-accent font-bold">
    Add to Playbook
  </button>
</div>
