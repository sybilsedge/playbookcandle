---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductGrid from "../components/ProductGrid.astro";
import About from "../components/About.astro";
import Newsletter from "../components/Newsletter.astro";

export const prerender = false;
---

<BaseLayout title="The Playbook Candle Co." description="Tactical Scent Concepts for Game Day.">
  <section class="mx-auto w-full max-w-6xl px-6 py-24">
    <div class="max-w-4xl rounded-2xl border border-line/70 bg-surface/80 p-10 md:p-16 shadow-xl relative overflow-hidden">
      <div class="absolute top-0 right-0 w-32 h-32 opacity-10 playbook-line -rotate-45 translate-x-10 -translate-y-10"></div>

      <p class="font-heading text-accent uppercase tracking-[0.25em] text-sm">Opening Drive</p>
      <h1 class="mt-4 font-heading text-5xl md:text-7xl leading-tight uppercase">
        Atmosphere is <br /> <span class="text-accent">Tactical</span>.
      </h1>
      <p class="mt-6 text-xl text-muted max-w-2xl leading-relaxed">
        Engineered scent concepts for the dedicated strategist. From the Friday Night lights to the Monday Morning film room.
      </p>

      <div class="mt-12 flex flex-wrap gap-4 items-center">
        <a href="#roster" class="rounded-lg bg-accent px-8 py-3 text-sm font-bold uppercase tracking-widest text-bg transition-opacity hover:opacity-90">
          View the Roster
        </a>
        <div class="flex gap-2">
          <a href="/?theme=modern" class="w-8 h-8 rounded-full bg-[#0d1117] border border-line hover:border-accent flex items-center justify-center transition-colors" title="Modern Coordinator">
             <span class="sr-only">Modern</span>
          </a>
          <a href="/?theme=chalkboard" class="w-8 h-8 rounded-full bg-[#1f3328] border border-line hover:border-accent flex items-center justify-center transition-colors" title="Friday Night Chalkboard">
             <span class="sr-only">Chalkboard</span>
          </a>
          <a href="/?theme=minimalist" class="w-8 h-8 rounded-full bg-[#181615] border border-line hover:border-accent flex items-center justify-center transition-colors" title="Gridiron Minimalist">
             <span class="sr-only">Minimalist</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <div id="roster">
    <ProductGrid />
  </div>

  <About />

  <Newsletter />
</BaseLayout>
