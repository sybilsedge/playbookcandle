---
---

<section class="mx-auto w-full max-w-6xl px-6 py-12 mb-20">
  <div class="rounded-2xl border-2 border-dashed border-line/70 bg-surface/30 p-8 md:p-12 text-center">
    <p class="font-heading text-accent uppercase tracking-[0.25em] text-sm">Opening Drive</p>
    <h2 class="mt-4 font-heading text-3xl md:text-5xl uppercase max-w-2xl mx-auto leading-tight">
      Get the Playbook Before Kickoff
    </h2>
    <p class="mt-4 text-muted max-w-md mx-auto">
      Join our scouting report to receive updates on new scent deployments and limited-edition gameday drops.
    </p>

    <form class="mt-8 flex flex-col sm:flex-row gap-3 max-w-lg mx-auto">
      <label for="newsletter-email" class="sr-only">Coach's Email Address</label>
      <input
        id="newsletter-email"
        name="email"
        type="email"
        autocomplete="email"
        placeholder="Coach's Email Address"
        class="flex-1 rounded-lg border border-line bg-bg px-4 py-3 text-sm focus:border-accent focus:outline-none transition-colors"
        required
      />
      <button
        type="submit"
        class="rounded-lg bg-accent px-8 py-3 text-sm font-bold uppercase tracking-widest text-bg transition-opacity hover:opacity-90"
      >
        Sign Up
      </button>
    </form>

    <p class="mt-4 text-[10px] uppercase tracking-widest text-muted/60">
      No Spam. Just Strategy.
    </p>
  </div>
</section>
